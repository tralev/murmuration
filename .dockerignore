SESSION_NOTES.md
BOUNDARY_MODES.md

# CI/CD workflows (not needed in Docker image)
.github/

# Helper scripts (used outside the container)
scripts/
run.sh
run-docker.sh
requirements.txt

# Jupyter notebooks (development-only)
notebooks/

# Octave workspace files (auto-generated)
octave-workspace
octave-core
*.oct-workspace

# Docker files themselves
Dockerfile
docker-compose.yml
.dockerignore

# Python virtual environment (not source code)
venv/

# Citation metadata (not needed in image)
CITATION.cff

# Binary / generated assets (not source code)
*.gif

# Educational iteration examples (not needed for Docker validation)
examples/
