# .dockerignore — keep the build context minimal.
# The Dockerfile does `COPY *.py *.sh` + LICENSE; everything else is excluded so
# it never reaches the build context.

# ── Version control ─────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Research papers & sources (large, not needed in the image) ──────
sci/
*.pdf
*.html
*.zip

# ── Runtime output (generated in the container, not baked in) ───────
output/
*.csv
*.gif

# ── Python artifacts / environments ─────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/

# ── Docs & metadata not needed at runtime ───────────────────────────
*.md
CITATION.cff
requirements.txt

# ── CI / Docker meta (not needed inside the image) ──────────────────
.github/
Dockerfile
docker-compose.yml
.dockerignore

# ── Notebooks (development only) ────────────────────────────────────
notebooks/

# ── IDE / OS cruft ──────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
