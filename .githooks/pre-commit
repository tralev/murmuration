#!/usr/bin/env bash
# pre-commit — runs the shared Python test gate (run_tests.sh: syntax check +
# 3D unit tests) and blocks the commit if it fails.
#
# This hook is tracked in the repo (unlike .git/hooks/). Enable it once per
# clone with:
#     git config core.hooksPath .githooks
#
# To bypass in an emergency:  git commit --no-verify
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

./run_tests.sh --quiet || {
    echo "  ✗ COMMIT BLOCKED (bypass with: git commit --no-verify)."
    exit 1
}
